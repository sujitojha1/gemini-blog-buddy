{
  "manifest_version": 3,
  "name": "Gemini Blog Buddy",
  "version": "1.0.0",
  "description": "Capture AI blogs into DuckDB, track your reading metrics intuitively, and build FAISS vector embeddings instantly.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gemini Blog Buddy",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
